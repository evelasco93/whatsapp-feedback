# App
APP_NAME=whatsapp-feedback-backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# CORS (comma-separated)
CORS_ORIGINS_RAW=*

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_DB_NAME=whatsapp_feedback
MONGODB_COLLECTION_NAME=mensajes

# Gemini (proveedor primario de analisis)
GEMINI_API_KEY=
# Ejemplo recomendado por usuario: gemini-3.5-flash
# Fallback por defecto en backend: gemini-flash-latest
GEMINI_MODEL=gemini-flash-latest
AI_TIMEOUT_SECONDS=15

# Twilio
VALIDATE_TWILIO_SIGNATURE=false
TWILIO_AUTH_TOKEN=

# SSE
SSE_RETRY_MS=3000
